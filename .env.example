# LLM Provider (anthropic | groq | openrouter)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Groq (used when LLM_PROVIDER=groq)
# GROQ_API_KEY=
# LLM_MODEL=llama3-70b-8192

# OpenRouter (used when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# LLM_MODEL=openai/gpt-4o

# Blockchain — Fuji
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
DEPLOYER_PRIVATE_KEY=
BUYER_PRIVATE_KEY=
SELLER_PRIVATE_KEY=

# Deployed contract addresses (fill after Phase 1 deploy)
AGENT_REGISTRY_ADDRESS=
NEGOTIATION_ENGINE_ADDRESS=
SKILL_REGISTRY_ADDRESS=

# Agent config
BUYER_BUDGET_CAP_USDC=100
SELLER_FLOOR_PRICE_USDC=40
MAX_NEGOTIATION_ROUNDS=5
POLL_INTERVAL_SECONDS=8
SERVICE_NICHE=data-analysis

# Marketplace
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_NEGOTIATION_ENGINE_ADDRESS=
NEXT_PUBLIC_SKILL_REGISTRY_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=43113

# Seller service
SELLER_SERVICE_PORT=5001
SELLER_SERVICE_ENDPOINT=http://localhost:5001/service
