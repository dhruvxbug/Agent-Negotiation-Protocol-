# LLM Provider (anthropic | groq | openrouter)
LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6     # Anthropic: claude-sonnet-4-6, claude-3-opus, etc.
# LLM_MODEL=llama3-70b-8192       # Groq: llama3-70b-8192, mixtral-8x7b-32768, etc.
# LLM_MODEL=openai/gpt-4o         # OpenRouter: openai/gpt-4o, anthropic/claude-sonnet-4-6, etc.

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Groq (used when LLM_PROVIDER=groq)
# GROQ_API_KEY=

# OpenRouter (used when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=

# Blockchain
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
BUYER_PRIVATE_KEY=
SELLER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

# Deployed contract addresses (fill after deploy)
NEGOTIATION_ENGINE_ADDRESS=
AGENT_REGISTRY_ADDRESS=

# Agent config
BUYER_BUDGET_CAP=100
SELLER_FLOOR_PRICE=40
MAX_ROUNDS=5
POLL_INTERVAL_SECONDS=8
